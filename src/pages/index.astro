---
import {
    ArrowRight,
    Brain,
    Workflow,
    Zap,
    Wrench,
    Search,
    Cloud,
    Mail,
    Calendar,
} from "@lucide/astro";
import Layout from "../layouts/Layout.astro";
import Service from "../components/home/Service.astro";
import Project from "../components/Project.astro";
---

<Layout title="Tsvetozar Biserov">
    <header
        class="mb-4 border-b border-white/10 pt-24 pb-12 md:pt-28"
        id="header">
        <p
            class="mb-6 inline-flex items-center gap-2 text-xs font-medium tracking-wide text-white/70 uppercase">
            Backend systems · automation · infrastructure tooling
        </p>
        <h1
            class="mb-6 text-4xl font-semibold tracking-tight text-balance text-white sm:text-5xl md:text-6xl">
            Backend engineering for performance-critical and operationally messy
            systems
        </h1>
        <p
            class="mb-8 max-w-2xl text-base leading-7 text-pretty text-white/75 sm:text-lg sm:leading-8">
            I build <u>Go</u> & <u>Rust</u> backends, internal tools, and admin dashboards
            that make systems faster, simpler, and cheaper to operate.
        </p>
        <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
                href="#contact"
                class="group inline-flex items-center justify-center rounded-lg bg-blue-700 px-4 py-3 text-sm font-semibold text-white shadow-sm shadow-indigo-500/20 transition hover:bg-blue-600 hover:shadow-md hover:shadow-indigo-500/30 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400">
                <ArrowRight
                    class="mr-2 size-4 transition-transform group-hover:translate-x-0.5"
                />
                Get in touch
            </a>
            <a
                href="#projects"
                class="inline-flex items-center justify-center rounded-lg border border-white/15 bg-white/5 px-5 py-3 text-sm font-semibold text-white/90 transition hover:bg-white/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/30">
                See projects
            </a>
        </div>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/60">
            <span class="inline-flex items-center gap-2">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-400/80"></span>
                Remote-friendly
            </span>
            <span class="inline-flex items-center gap-2">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-400/80"></span>
                English · Spanish · Catalan · Bulgarian
            </span>
            <span class="inline-flex items-center gap-2">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-400/80"></span>
                Typical projects: 2-6 weeks
            </span>
        </div>
    </header>

    <div class="flex flex-col gap-12">
        <section class="flex flex-col gap-4" id="about">
            <h2 class="text-2xl font-bold text-white">About me</h2>
            <p class="text-base leading-7 text-pretty text-white/70">
                I'm Tsvetozar, a software developer currently working as a
                freelancer. I have a strong background in backend development,
                with a focus on performance-critical systems and operational
                tooling. I am passionate about building scalable solutions that
                make complex systems easier to manage and more efficient. I have
                experience working with a variety of technologies, including Go
                and Rust. I enjoy learning new technologies and improving my
                skills.
            </p>
        </section>
        <section class="flex flex-col gap-6" id="services">
            <h2 class="text-2xl font-bold text-white">
                How can I help your team?
            </h2>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div class="grid grid-rows-3 gap-y-4">
                    <div class="row-span-2 h-full">
                        <Service
                            title="High-performance backends"
                            description="Build fast, memory-safe, and efficient backends for performance-critical systems."
                            features={[
                                "Go and Rust native development",
                                "Optimized for low latency, high throughput, and reliability",
                            ]}
                            icon={Zap}
                        />
                    </div>
                    <div class="row-span-1 h-full">
                        <Service
                            title="Reverse Engineering"
                            description="Product analysis, closed-system integration and deep-tech CLI tools."
                            icon={Search}
                        />
                    </div>
                </div>
                <div class="grid grid-rows-3 gap-y-4">
                    <div class="row-span-1 h-full">
                        <Service
                            title="Cloud & Infrastructure"
                            description="Containerization, CI/CD, and Linux system tuning for maximum uptime."
                            icon={Cloud}
                        />
                    </div>
                    <div class="order-first row-span-2 h-full md:order-0">
                        <Service
                            title="Operations automation"
                            description="Replace manual workflows with reliable services and internal tooling."
                            features={[
                                "Billing & provisioning pipelines",
                                "Custom dashboards and backoffices",
                                "Error reduction",
                            ]}
                            icon={Workflow}
                        />
                    </div>
                </div>
                <div class="grid grid-rows-3 gap-y-4">
                    <div class="row-span-2 h-full">
                        <Service
                            title="Architecture Rescue"
                            description="Audit and refactor unstable & legacy codebases to modern, maintainable architectures."
                            features={[
                                "Deadlock & leak hunting",
                                "Legacy code modernization",
                                "Technical debt reduction",
                            ]}
                            icon={Wrench}
                        />
                    </div>
                    <div class="row-span-1 h-full">
                        <Service
                            title="Technical Consulting"
                            description="Code reviews, infrastructure planning, and bottleneck analysis."
                            icon={Brain}
                        />
                    </div>
                </div>
            </div>

            <section class="flex flex-col gap-6" id="projects">
                <h3 class="text-2xl font-bold text-white">Featured projects</h3>
                <div
                    class="grid grid-cols-1 grid-rows-2 gap-4 md:grid-cols-2 xl:grid-cols-2">
                    <Project
                        name="Lumen Proxy"
                        description="High-performance network proxy designed for low-latency routing and massive concurrent connection management."
                        stack={[
                            "Rust",
                            "Networking",
                            "Perf",
                            "Balancing",
                            "Tokio",
                            "Concurrent Systems",
                        ]}
                        category="Systems"
                    />
                    <div class="row-span-2">
                        <Project
                            link="/projects/simcenter"
                            name="Simcenter Software"
                            description="Distributed management system for racing simulation centers, handling real-time hardware control and center-wide orchestration."
                            stack={[
                                "Go",
                                "Svelte",
                                "Networking",
                                "Distributed Systems",
                            ]}
                            image="/images/simcenter.png"
                            category="App"
                        />
                    </div>
                    <Project
                        name="Billing & Provisioning"
                        description="Custom billing engine and provisioning pipeline that centralizes multiple payment gateways (PSPs) into a unified automated workflow."
                        stack={[
                            "Go",
                            "Svelte",
                            "Payments Integration",
                            "API Design",
                            "Architecture",
                        ]}
                        category="Automation"
                    />
                </div>
            </section>
        </section>
        <section class="flex flex-col gap-4" id="contact">
            <h2 class="text-2xl font-bold text-white">Get in touch</h2>
            <p class="text-base leading-7 text-pretty text-white/70">
                If you're interested in working together or just want to say hi,
                feel free to reach out! I'm always open to discussing new
                projects, collaborations, or opportunities to contribute to
                interesting work.
            </p>
            <div class="flex flex-row gap-2">
                <a
                    href="mailto:contact@chechu.dev"
                    class="group inline-flex items-center justify-center rounded-md border border-white/20 bg-white/10 px-4 py-2 text-sm text-white shadow-sm transition hover:bg-white/20 hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
                    <Mail class="mr-2 size-4" />
                    Send an email
                </a>
                <!-- Calendly link widget begin -->
                <link
                    href="https://assets.calendly.com/assets/external/widget.css"
                    rel="stylesheet"
                />
                <script
                    src="https://assets.calendly.com/assets/external/widget.js"
                    type="text/javascript"
                    async
                ></script>
                <!-- Calendly link widget end -->
                <button
                    onclick="Calendly.initPopupWidget({url: 'https://calendly.com/contact-chechu/30min'});return false;"
                    class="group inline-flex cursor-pointer items-center justify-center rounded-md border border-white/20 bg-white/10 px-4 py-2 text-sm text-white shadow-sm transition hover:bg-white/20 hover:shadow-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
                    <Calendar class="mr-2 size-4" />
                    Schedule a meeting
                </button>
            </div>
        </section>
    </div>
</Layout>
