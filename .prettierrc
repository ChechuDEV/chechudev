{
    "plugins": ["prettier-plugin-astro", "prettier-plugin-tailwindcss"],
    "overrides": [
        {
            "files": "*.astro",
            "options": {
                "parser": "astro",
                "bracketSameLine": true,
                "htmlWhitespaceSensitivity": "ignore"
            }
        },
        {
            "files": "*.mdx",
            "options": {
                "parser": "markdown",
                "proseWrap": "always"
            }
        }
    ],
    "tabWidth": 4,
    "useTabs": false
}
